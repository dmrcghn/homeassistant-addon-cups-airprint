#!/usr/bin/with-contenv bashio

ulimit -n 524288

bashio::log.info "Starting CUPS server from S6"

until [ -e /var/run/avahi-daemon/socket ]; do
  sleep 1s
done

bashio::log.info "Preparing directories"
if [ ! -d /config/cups ]; then cp -v -R /etc/cups /config; fi
rm -v -fR /etc/cups
ln -v -sf /config/cups /etc/cups

bashio::log.info "Starting cupsd"
exec cupsd -f
